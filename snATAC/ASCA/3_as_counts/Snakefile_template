# Get AS counts per donor and cell type
rule get_AS_counts_per_variant:
    input: 
        bam = bam_dir + "/{brain_region}/{donor}/{cluster}.bam",
        vcf = vcf
    output: analysis_dir + "/AS_counts/per_variant/{brain_region}/{donor}/{cluster}.variant_counts.txt.gz"
    threads: 2
    params:
        script = wasp_dir + "/mapping/get_counts.py",
        outdir = analysis_dir + "/AS_counts/per_variant/{brain_region}/{donor}"
    message: ruleDisplayMessage + "Getting AS counts per variant"
    shell: """
            module load SAMtools/1.21-GCC-10.3.0;
            samtools index {input.bam};
            mkdir -p {params.outdir};
            python {params.script} \
                    --bam {input.bam} \
                    --vcf {input.vcf} \
                    --sample {wildcards.donor} \
                    --outprefix {params.outdir}/{wildcards.cluster} &>> log/{wildcards.cluster}.get_counts.log;
           """


