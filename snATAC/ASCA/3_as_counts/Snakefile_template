rule split_counts_per_haplotype:
    input: rules.get_AS_counts_per_variant.output
    output: 
        hap1 = temp(analysis_dir + "/AS_counts/per_haplotype/{brain_region}/{donor}/{cluster}.hap1.bedgraph"),
        hap2 = temp(analysis_dir + "/AS_counts/per_haplotype/{brain_region}/{donor}/{cluster}.hap2.bedgraph")
    threads: 2
    message: ruleDisplayMessage + "Splitting counts per haplotype for {wildcards.donor} in {wildcards.cluster}"
    params:
        outdir = analysis_dir + "/AS_counts/per_haplotype/{donor}",
        script = wasp_dir + "/as_counts/split_allelic_counts_per_haplotype.py"
    shell: """
            mkdir -p {params.outdir};
            zcat {input} | grep -E '^#|0\|1|1\|0'  > {input}_filtered.tsv;
            python {params.script} \
                    --counts {input} \
                    --hap1 {output.hap1} \
                    --hap2 {output.hap2};
            rm {input}_filtered.tsv
           """

           

# replace sum by max (getting max signal per window)
rule bg_signal_over_windows:
    input:
        bg = analysis_dir + "/AS_counts/per_haplotype/{brain_region}/{donor}/{cluster}.{hap}.bedgraph",
        windows = genome_windows
    output: temp(analysis_dir + "/AS_counts/per_haplotype/{brain_region}/{donor}/{cluster}.{hap}.binned.bedgraph")
    threads: 1
    message: ruleDisplayMessage + "Summing bedgraph signal over genome windows"
    params:
        outdir = analysis_dir + "/AS_counts/per_haplotype/{brain_region}/{donor}"
    shell: """
            module load BEDTools/2.31.1-GCC-10.3.0;
            bedtools map -a {input.windows} -b {input.bg} -c 4 -o max > {output};
            sed -i 's/\./0/g' {output}
           """



# convert bedgraph to bigwig
rule bg_to_bw:
    input:
        bg = rules.bg_signal_over_windows.output
    output: analysis_dir + "/AS_counts/per_haplotype/{brain_region}/{donor}/{cluster}.{hap}.bw"
    threads: 1
    message: ruleDisplayMessage + "Converting bedgraph to bigwig"
    params:
        chromsizes = chromsizes
    shell: """
            {bedGraphToBigWig} {input.bg} {params.chromsizes} {output}
           """


