def get_cluster_names_for_donors(donors, barcodes_path):
    df = pd.read_csv(barcodes_path, sep = "\t")
    df = df[df["donor_id"].isin(donors)]
    clusters = df["cluster_name"].unique()
    return clusters

def match_donors_with_clusters(donors, barcodes_path, min_cells = 0, cell_types = None):
    df = pd.read_csv(barcodes_path, sep = "\t")
    if cell_types:
        df = df[df.cell_type.isin(cell_types)]
    df = df[(df.donor_id.isin(donors)) & (df.n_cells > min_cells) ][["donor_id", "cluster_name", "brain_region"]].drop_duplicates()
    return (df.donor_id.to_list(), df.cluster_name.to_list(), df.brain_region.to_list())
    
