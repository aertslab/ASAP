ruleDisplayMessage = """\n\n####### START RULE EXECUTION ##########\n"""


################################################################################
######################## SET UP ################################################
################################################################################

def get_donor_id_from_bam(bam_file):
    return bam_file.split("/")[-1].split(".")[0]

def get_sample_name_from_bam(bam_file):
    return bam_file.split("/")[-2]

def get_bam_files_per_donor(donor, bam_files):
    return [bam_file for bam_file in bam_files if donor in bam_file]

def get_donor_vcf(donor, vcf_dir):
    vcf_path = glob.glob(vcf_dir + f"/{donor}*/{donor}*/longphase_phase/{donor}*_longphase.vcf.gz")[0]
    return vcf_path

def get_donor_region_pattern(bam_file):
    pattern = os.path.join(os.path.basename(os.path.dirname(bam_file)), os.path.basename(bam_file).replace(".bam", ""))
    return pattern 

