rule all:
    input:
        expand(outdir + "/{donor_pattern}.mappability_filter.sorted.full.bam", donor_pattern = donor_pattern),
        expand(outdir + "/{donor_pattern}.mappability_filter.sorted.with_variants.bam", donor_pattern = donor_pattern)



# Place alignments not overlapping variants in a BAM file and extract reads overlapping variants, and their allele flipped versions, to a fastq file.
# Using VCF file per donor (not merged)
rule filter_first_alignment:
    input:
        bam = bam_dir + "/{brain_region}/{donor}.bam",
        vcf = lambda wildcards : get_donor_vcf(wildcards.donor, vcf_dir)
    output:
        bam = temp(outdir + "/{brain_region}/{donor}.no_variants.bam"),
        fastq = temp(outdir + "/{brain_region}/{donor}.allele_flipped.fq.gz"),
        info = outdir + "/{brain_region}/{donor}.allele_flipped_log.txt"
    params:
        prefix = outdir + "/{brain_region}/{donor}",
        mapq = 10,
        max_vars = 8,
        max_seqs = 256
    shell:
        """
        python {wasp_dir}/mapping/generate_variant_reads.py \
                     --min_mapq {params.mapq} \
                     --max_vars {params.max_vars} \
                     --max_seqs {params.max_seqs} \
                     --bam {input.bam} \
                     --vcf {input.vcf} \
                     --out_prefix {params.prefix} &>> {params.prefix}.allele_flipped_stdout.txt
        """


# Align allele flipped reads to the reference genome
# Specific adaptations for the allele flipped bam files (in bwa_mem2_mapping.sh): 
#  -p flag for interleaved paired-end reads in a single fastq file
#  -R "@RG\tID:${fastq_basename_prefix}\tSM:${sample_id}\tLB:${library_id}__${sample_id}\tPL:ILLUMINA" - different from original bam file
rule align_allele_flipped:
    input:
        fastq = rules.filter_first_alignment.output.fastq
    output:
        bam = temp(outdir + "/{brain_region}/{donor}.allele_flipped.bwa.out.fixmate.bam")
    params:
        outdir = outdir + "/{brain_region}/",
        prefix = outdir + "/{brain_region}/{donor}"
    shell:
        """
        bash bwa_mem2_mapping.sh {input.fastq} {wildcards.donor} {params.outdir} 
        """


# Sort the remapped BAM file with allele flipped reads
# Important notes: use -SO queryname to keep together reads with allele flips
rule sort_remapped_bam:
    input:
        bam = rules.align_allele_flipped.output.bam
    output:
        bam = temp(outdir + "/{brain_region}/{donor}_remapped_sorted.bam"),
    params:
        outdir = outdir + "/{brain_region}",
        tmpdir = "/scratch/leuven/350/vsc35059/picard"
    message: "Sort remapped bam file for {wildcards.donor}"
    shell:
        """
        module load picard/3.1.1-Java-19.0.2; 
        java -jar $EBROOTPICARD/picard.jar SortSam -I {input.bam} -O {output.bam} -SO queryname -CREATE_INDEX true --TMP_DIR {params.tmpdir};
        """



# # Extract reads for which the original and allele flipped version align to the same location
rule filter_second_alignment:
    input: rules.sort_remapped_bam.output
    output:
        bam = temp(outdir + "/{brain_region}/{donor}.consistent.bam"),
        log = outdir + "/{brain_region}/{donor}.second_alignment_log.txt"
    params:
        prefix = outdir + "/{brain_region}/{donor}",
        mapq = 10
    shell:
        """
        python {wasp_dir}/mapping/filter_remapped_reads.py  \
               --min_mapq {params.mapq} {input} {params.prefix}
        """


# Merge all passed alignments
# Important notes: use -r option to keep the read group information from both files in the output file
rule merge_filt_bams:
    input:
        bam1 = rules.filter_first_alignment.output.bam,
        bam2 = rules.filter_second_alignment.output.bam
    output: 
        bam_merged = temp(outdir + "/{brain_region}/{donor}.mappability_filter.full.bam"),
        bam_sorted = outdir + "/{brain_region}/{donor}.mappability_filter.sorted.full.bam"
    threads: 16
    shell:
        """
        module load SAMtools/1.21-GCC-10.3.0;
        module load picard/3.1.1-Java-19.0.2; 
        samtools merge -r -O BAM -@ {threads} {output.bam_merged} {input.bam1} {input.bam2};
        java -jar $EBROOTPICARD/picard.jar SortSam I={output.bam_merged} O={output.bam_sorted} SO=coordinate CREATE_INDEX=true   
        """


# Get sorted bam file containing reads that overlap variants (after mappability filter)
rule sort_second_alignment:
    input:
        bam = rules.filter_second_alignment.output.bam
    output:
        bam = outdir + "/{brain_region}/{donor}.mappability_filter.sorted.with_variants.bam",
    params:
        outdir = outdir + "/{brain_region}",
        tmpdir = "/scratch/leuven/350/vsc35059/picard"
    message: "Sort bam file for {wildcards.donor}, index and get stats"
    shell:
        """
        module load picard/3.1.1-Java-19.0.2;
        java -jar $EBROOTPICARD/picard.jar SortSam -I {input.bam} -O {output.bam} -SO coordinate -CREATE_INDEX true --TMP_DIR {params.tmpdir};
        """