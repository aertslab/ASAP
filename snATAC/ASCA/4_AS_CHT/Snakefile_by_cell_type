analysis_dir = "/staging/leuven/stg_00090/ASA/analysis/2024_T2T_ATAC_analysis/20250107_allelic_analysis"
wasp_dir = "/staging/leuven/stg_00090/ASA/src/wasp_indel_v1.0/"

