#SBATCH -c 25
##SBATCH -mem 200G
#SBATCH --time=10:00:00
#SBATCH -A XX
#SBATCH -p batch
#SBATCH --cluster wice
#SBATCH --job-name=modkit
#SBATCH --array=1-125
#SBATCH -o /logs/modkit_%j_%A_%a.out
#SBATCH -e /logs/modkit_%j_%A_%a.err

# to tun modkit pileup and extract methylation information from the samples
